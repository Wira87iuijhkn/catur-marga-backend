# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/catur-marga-lms
# For Railway: mongodb+srv://username:password@cluster.mongodb.net/catur-marga-lms

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
